{
  "name": "tangbao-web",
  "version": "1.0.1",
  "private": true,
  "description": "糖包 - 全能 AI 助手桌面版（含糖码本地后端）",
  "author": "糖包",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/agent-server.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.tangbao.desktop",
    "productName": "糖包",
    "icon": "assets/app-icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "js/**/*",
      "assets/**/*",
      "vendor/**/*",
      "server/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "artifactName": "糖包-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.2"
  }
}
